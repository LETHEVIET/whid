{
  "name": "whid",
  "version": "0.1.0",
  "description": "A quick-capture scratchpad for fleeting thoughts",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "generate-icon": "node scripts/generate-icons.mjs",
    "build": "electron-vite build && pnpm generate-icon",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && pnpm generate-icon && electron-builder",
    "rebuild": "electron-rebuild",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "better-sqlite3": "^11.6.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.16.0",
    "react-activity-calendar": "^3.2.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.34.5",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "sharp"
    ]
  },
  "build": {
    "appId": "com.whid.app",
    "productName": "Whid",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "LETHEVIET",
      "repo": "whid"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "extraResources": [
      "build/tray-icon.png",
      "build/window-icon.png"
    ]
  }
}
